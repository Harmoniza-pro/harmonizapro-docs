    {
      "parameters": {
        "jsCode": "const itemsInput = $input.all();\n\nfunction sanitizeText(value) {\n  if (!value || typeof value !== 'string') return value;\n\n  return value\n    .replace(/[\\p{Emoji_Presentation}\\p{Extended_Pictographic}]/gu, '') // remove emojis\n    .replace(/[{}]/g, '')\n    .replace(/\\s+\\?/g, '?')\n    .replace(/\\s+/g, ' ')\n    .trim();\n}\n\nfunction sentenceCase(str) {\n  if (!str) return str;\n  const cleaned = str.toLowerCase().trim();\n  return cleaned.charAt(0).toUpperCase() + cleaned.slice(1);\n}\n\nfunction cleanFormularioTitle(title) {\n  if (!title) return null;\n  return title.replace(/\\s*\\[.*?\\]\\s*/g, '').trim();\n}\n\nfunction getAnswerValue(answer) {\n  switch (answer.type) {\n    case 'text':\n      return answer.text;\n\n    case 'phone_number':\n      return answer.phone_number;\n\n    case 'choice':\n      return answer.choice?.label;\n\n    case 'choices':\n      return answer.choices?.labels?.join(', ');\n\n    case 'number':\n      return String(answer.number);\n\n    case 'email':\n      return answer.email;\n\n    default:\n      return null;\n  }\n}\n\n/**\n * Limpa e extrai a \"pergunta real\" do título do Typeform\n */\nfunction extractQuestion(fieldTitle) {\n  if (!fieldTitle) return null;\n\n  let t = String(fieldTitle);\n\n  // remove {{field}}\n  t = t.replace(/\\{\\{.*?\\}\\}/g, '');\n\n  // remove markdown do typeform\n  t = t.replace(/\\*/g, '');\n\n  // normaliza linhas\n  t = t.replace(/\\n+/g, ' ');\n\n  t = sanitizeText(t);\n\n  // remove textos de copy iniciais\n  const prefixes = [\n    'aqui no consultório',\n    'aqui na clínica',\n    'ótimo',\n    'entendi',\n    'agora me conta',\n    'agora uma pergunta importante',\n    'mais uma pergunta importante',\n    'para finalizarmos',\n    'para prepararmos sua consulta'\n  ];\n\n  const lower = t.toLowerCase();\n\n  for (const p of prefixes) {\n    const idx = lower.indexOf(p);\n    if (idx !== -1) {\n      t = t.slice(idx + p.length).trim();\n      break;\n    }\n  }\n\n  // remove vírgula ou dois pontos no começo\n  t = t.replace(/^[,:\\-\\s]+/, '');\n\n  // se tiver vírgula, pega trecho após a última\n  if (t.includes(',')) {\n    const parts = t.split(',').map(p => p.trim()).filter(Boolean);\n    if (parts.length >= 2) t = parts[parts.length - 1];\n  }\n\n  // sentence case\n  return sentenceCase(sanitizeText(t));\n}\n\nconst output = [];\n\nfor (const item of itemsInput) {\n  const formResponse = item.json?.body?.form_response;\n\n  if (!formResponse?.answers || !formResponse?.definition?.fields) {\n    output.push({ json: { error: 'Resposta não encontrada' }});\n    continue;\n  }\n\n  const { answers, definition, form_id } = formResponse;\n\n  const fieldById = Object.fromEntries(\n    definition.fields.map(f => [f.id, f])\n  );\n\n  const responsesByFieldId = {};\n  const respostas = [];\n\n  let nome = null;\n  let telefone = null;\n\n  for (const answer of answers) {\n    const field = fieldById[answer.field.id];\n    if (!field) continue;\n\n    const rawValue = getAnswerValue(answer);\n    const value = sanitizeText(rawValue);\n    const pergunta = extractQuestion(field.title);\n\n    if (field.id && value) {\n      responsesByFieldId[field.id] = value;\n    }\n\n    // Nome\n    if (pergunta === 'First name') {\n      nome = value;\n      continue;\n    }\n\n    // Telefone\n    if (answer.type === 'phone_number') {\n      telefone = value;\n      continue;\n    }\n\n    // ignora vazios\n    if (!pergunta || !value) continue;\n\n    // Se a \"pergunta\" ainda ficar como copy sem interrogação e muito curta/ruim, ignora\n    // (mantém as que fazem sentido)\n    if (pergunta.toLowerCase().includes('protocolo') && pergunta.length > 80 && !pergunta.includes('?')) {\n      continue;\n    }\n\n    respostas.push(`${pergunta}: ${value}`);\n  }\n\n  output.push({\n    json: {\n      nome,\n      telefone,\n      dra: cleanFormularioTitle(definition.title),\n      formulario: cleanFormularioTitle(definition.title),\n      form_id: form_id || null,\n      respostas_por_campo: responsesByFieldId,\n      respostas_formatadas: respostas.join('\\n\\n')\n    }\n  });\n}\n\nreturn output;\n"
      },
