      "parameters": {
        "jsCode": "const custom_fields = [\n  {\n    \"id\": $item(\"0\").$node[\"Edit Fields\"].json[\"Campo Telefone\"],\n    \"value\": $item(\"0\").$node[\"Edit Fields\"].json[\"Telefone\"]\n  },\n  {\n    \"id\": $item(\"0\").$node[\"Edit Fields\"].json[\"Campo Data Entrada\"],\n    \"value\": $item(\"0\").$node[\"Edit Fields\"].json[\"Data\"]\n  },\n  {\n    \"id\": $item(\"0\").$node[\"Edit Fields\"].json[\"Campo Link Wpp\"],\n    \"value\": \"https://wa.me/\" + $item(\"0\").$node[\"Edit Fields\"].json[\"Telefone\"].replace(/[^0-9]/g,\"\")\n  },\n  {\n    \"id\": $item(\"0\").$node[\"Edit Fields\"].json[\"Campo Clínica\"],\n    \"value\": $item(\"0\").$node[\"Edit Fields\"].json[\"Clínica\"]\n  },\n  {\n    \"id\": $item(\"0\").$node[\"Edit Fields\"].json[\"Campo Canal\"],\n    \"value\": \"e29e476d-8cc3-4bdc-9153-98623c40fc27\"\n  },\n  {\n    \"id\": $item(\"0\").$node[\"Edit Fields\"].json[\"Campo Protocolo\"],\n    \"value\": $item(\"0\").$node[\"Edit Fields\"].json[\"Protocolo\"]\n  },\n  {\n    \"id\": $item(\"0\").$node[\"Edit Fields\"].json[\"Campo Contexto\"],\n    \"value\": $item(\"0\").$node[\"Code\"].json[\"respostas_formatadas\"]\n  }\n]\n\nreturn custom_fields"
