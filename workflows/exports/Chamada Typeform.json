    {
      "parameters": {
        "jsCode": "const seen = new Set();\nconst out = [];\n\nfor (const item of items) {\n  const phone =\n    item.json.telefone_normalizado ||\n    item.json.Number ||\n    item.json.phone;\n\n  // se não tiver phone, deixa passar\n  if (!phone) { out.push(item); continue; }\n\n  // remove duplicados\n  if (seen.has(phone)) continue;\n\n  seen.add(phone);\n  out.push(item);\n}\n\nreturn out;\n"
      },
