    {
      "parameters": {
        "jsCode": "// === Entradas ===\n// \"HTTP Request5\": node com a resposta da API (body.data)\n// \"HTTP Request6\": node com custom_event_type\n// \"Loop Over Items\": node com adset_id/adset_name/date_start/date_stop\n\nconst bodyData = $item(0).$node[\"HTTP Request5\"].json.body?.data || [];\nconst loopData = $item(0).$node[\"Loop Over Items\"].json || [];\n\n// Captura o custom_event_type do outro node\nconst customEventType = String(\n  $item(0).$node[\"HTTP Request6\"].json?.body?.promoted_object?.custom_event_type || ''\n).toUpperCase();\n\nconst results = [];\n\nfor (const loop of (Array.isArray(loopData) ? loopData : [loopData])) {\n  const adsetId = loop.adset_id;\n  const adsetName = loop.adset_name;\n  const dateStart = loop.date_start;\n  const dateStop  = loop.date_stop;\n  const campaign_name = loop.campaign_name;\n\n  const insight = bodyData.find(\n    i => i.date_start === dateStart && i.date_stop === dateStop\n  );\n\n  let valor = 0;\n  let resultado = 0;\n  let objetivo = '';\n\n  if (insight) {\n    valor = parseFloat(insight.spend || 0);\n    objetivo = String(insight.optimization_goal || '');\n\n    // ====== Regras de seleção ======\n    const actions = insight.actions || [];\n    const conversions = insight.conversions || [];\n\n    if (customEventType === 'CONTACT') {\n      const act = actions.find(a => a.action_type === 'offsite_conversion.fb_pixel_custom');\n      resultado = act ? parseFloat(act.value || 0) : 0;\n    }\n\n    else if (customEventType === 'PURCHASE') {\n      let act = actions.find(a => a.action_type === 'offsite_conversion.purchase');\n      if (!act) act = actions.find(a => a.action_type === 'offsite_conversion.fb_pixel_purchase');\n      resultado = act ? parseFloat(act.value || 0) : 0;\n    }\n\n    else if (['LEAD', 'GENERATE_LEAD', 'GENERATELEAD'].includes(customEventType)) {\n      const act = actions.find(a => a.action_type === 'offsite_conversion.lead');\n      resultado = act ? parseFloat(act.value || 0) : 0;\n    }\n      \n    else if (customEventType === 'OTHER') {\n      const con = conversions.find(\n        a => a.action_type === 'offsite_conversion.fb_pixel_custom.TypeformSubmit'\n      );\n      resultado = con ? parseFloat(con.value || 0) : 0;\n    }\n  }\n\n  // custo_por_resultado = valor / resultado (proteção contra divisão por zero)\n  const custoPorResultado =\n    Number.isFinite(valor) && resultado > 0 ? valor / resultado : null;\n\n  results.push({\n    json: {\n      data: dateStart,                    // Data do insight\n      adset_id: adsetId,                  // ID do conjunto\n      adset_name: adsetName,              // Nome do conjunto\n      campaign_name: campaign_name,\n      valor: valor,                       // Spend (investimento)\n      resultado: resultado,               // Métrica (varia por custom_event_type)\n      objetivo: $item(0).$node[\"HTTP Request6\"].json?.body?.promoted_object?.custom_event_str,                 // optimization_goal\n      custom_event_type: customEventType, // rastreamento do tipo de evento\n      custo_por_resultado: custoPorResultado\n    },\n  });\n}\n\nreturn results;"
      },
