    {
      "parameters": {
        "jsCode": "// === Entradas ===\n// \"HTTP Request\": node com a resposta da API (body.data)\n// \"Loop Over Items\": node com adset_id/adset_name/date_start/date_stop\n\nconst bodyData = $item(0).$node[\"HTTP Request5\"].json.body?.data || [];\nconst loopData = $item(0).$node[\"Loop Over Items\"].json || [];\n\nconst results = [];\n\nfor (const loop of (Array.isArray(loopData) ? loopData : [loopData])) {\n  const adsetId = loop.adset_id;\n  const adsetName = loop.adset_name;\n  const dateStart = loop.date_start;\n  const dateStop  = loop.date_stop;\n  const campaign_name = loop.campaign_name;\n\n  const insight = bodyData.find(\n    i => i.date_start === dateStart && i.date_stop === dateStop\n  );\n\n  let valor = 0;\n  let resultado = 0;\n  let objetivo = '';\n\n  if (insight) {\n    valor = parseFloat(insight.spend || 0);\n    objetivo = String(insight.optimization_goal || '');\n\n    // ====== Regras de cálculo do resultado ======\n    if (objetivo === 'REPLIES') {\n      const act = (insight.actions || []).find(\n        a => a.action_type === 'onsite_conversion.total_messaging_connection'\n      );\n      resultado = act ? parseFloat(act.value || 0) : 0;\n    }\n\n    else if (objetivo === 'PROFILE_VISIT') {\n      const act = (insight.actions || []).find(\n        a => a.action_type === 'link_click'\n      );\n      resultado = act ? parseFloat(act.value || 0) : 0;\n    }\n  }\n\n  // ====== Custo por resultado ======\n  const custoPorResultado = resultado > 0 ? valor / resultado : 0;\n\n  results.push({\n    json: {\n      data: dateStart,           // loop over items .date_start\n      adset_id: adsetId,         // loop over items .adset_id\n      adset_name: adsetName,     // loop over items .adset_name\n      campaign_name: campaign_name,\n      valor: valor,              // spend\n      resultado: resultado,      // métrica alvo\n      objetivo: objetivo,        // optimization_goal\n      custo_por_resultado: custoPorResultado // novo campo\n    },\n  });\n}\n\nreturn results;\n"
      },
